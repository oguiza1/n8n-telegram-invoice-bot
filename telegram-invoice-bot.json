    {
      "parameters": {
        "jsCode": "const cliente = $('Buscar cliente').first().json;\nconst datos = $('Parsear respuesta JSON').first().json.datos;\nconst productos = datos.productos || [];\n\nconst numero_factura = 'FAC-' + $now.toFormat('yyyy') + '-' + $now.toMillis();\nconst fecha = $now.toFormat('dd/MM/yyyy');\n\nlet base_imponible = 0;\nlet lineas = [];\n\nproductos.forEach((p, i) => {\n  const precio = parseFloat(p.precio || 0);\n  const cantidad = parseInt(p.cantidad || 1);\n  const subtotal = precio * cantidad;\n  base_imponible += subtotal;\n  lineas.push(`${p.nombre} x${cantidad} — ${precio.toFixed(2)}€/ud = ${subtotal.toFixed(2)}€`);\n});\n\nconst iva = base_imponible * 0.21;\nconst total = base_imponible + iva;\n\nreturn [{\n  json: {\n    numero_factura,\n    fecha,\n    cliente_nombre: cliente.Nombre || datos.cliente_nombre,\n    cliente_empresa: cliente.Empresa || '',\n    cliente_email: cliente.Email || '',\n    cliente_direccion: cliente.Direccion || '',\n    lineas: lineas.join('\\n'),\n    base_imponible: base_imponible.toFixed(2),\n    iva: iva.toFixed(2),\n    total: total.toFixed(2),\n    notas: datos.notas || '',\n    chat_id: $('Parsear respuesta JSON').first().json.chat_id\n  }\n}];",
        "chatId": "",
        "text": "",
        "documentURL": ""
      },
